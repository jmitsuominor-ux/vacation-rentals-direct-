# Which BookingProvider implementation lib/booking/index.ts hands out.
# Currently only "hostaway" exists — add new cases as new providers are built.
BOOKING_PROVIDER=hostaway

# Hostaway Public API (Settings > Public API in the Hostaway dashboard)
HOSTAWAY_ACCOUNT_ID=
HOSTAWAY_API_KEY=

# The channelId Hostaway uses for reservations you create yourself (not synced
# from Airbnb/VRBO). Confirm the correct value for this account in the
# Hostaway dashboard or API docs before going live.
HOSTAWAY_DIRECT_CHANNEL_ID=

# Basic auth credentials you set when registering the Hostaway unified
# webhook (dashboard or API) pointing at /api/webhooks/hostaway.
HOSTAWAY_WEBHOOK_USER=
HOSTAWAY_WEBHOOK_PASSWORD=
